Host *
    AddKeysToAgent yes
    UseKeychain yes

# Default Github 
Host github.com
    HostName github.com
    User git
    PreferredAuthentications publickey
    IdentityFile ~/.ssh/id_rsa
    IdentitiesOnly yes

# Deloitte Github
Host deloitte.github.com
    HostName github.com
    User git
    PreferredAuthentications publickey
    IdentityFile ~/.ssh/id_rsa_danipan-deloitte
    IdentitiesOnly yes